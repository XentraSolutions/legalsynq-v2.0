{
  "Urls": "http://0.0.0.0:5000",
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "REPLACE_VIA_SECRET_minimum_32_characters_long",
    "ExpiryMinutes": "60"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-login": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 1,
        "Match": {
          "Path": "/identity/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "identity-service-health": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 2,
        "Match": {
          "Path": "/identity/health"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "identity-service-info": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 3,
        "Match": {
          "Path": "/identity/info"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "identity-protected": {
        "ClusterId": "identity-cluster",
        "Order": 100,
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "fund-service-health": {
        "ClusterId": "fund-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 10,
        "Match": {
          "Path": "/fund/health"
        },
        "Transforms": [
          { "PathRemovePrefix": "/fund" }
        ]
      },
      "fund-service-info": {
        "ClusterId": "fund-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 11,
        "Match": {
          "Path": "/fund/info"
        },
        "Transforms": [
          { "PathRemovePrefix": "/fund" }
        ]
      },
      "fund-protected": {
        "ClusterId": "fund-cluster",
        "Order": 110,
        "Match": {
          "Path": "/fund/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/fund" }
        ]
      },
      "careconnect-service-health": {
        "ClusterId": "careconnect-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 20,
        "Match": {
          "Path": "/careconnect/health"
        },
        "Transforms": [
          { "PathRemovePrefix": "/careconnect" }
        ]
      },
      "careconnect-service-info": {
        "ClusterId": "careconnect-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": 21,
        "Match": {
          "Path": "/careconnect/info"
        },
        "Transforms": [
          { "PathRemovePrefix": "/careconnect" }
        ]
      },
      "careconnect-protected": {
        "ClusterId": "careconnect-cluster",
        "Order": 120,
        "Match": {
          "Path": "/careconnect/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/careconnect" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-primary": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "fund-cluster": {
        "Destinations": {
          "fund-primary": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "careconnect-cluster": {
        "Destinations": {
          "careconnect-primary": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
