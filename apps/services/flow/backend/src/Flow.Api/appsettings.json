{
  "Urls": "http://0.0.0.0:5012",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FlowDb": "Server=localhost;Database=flow_db;User=root;Password=;"
  },
