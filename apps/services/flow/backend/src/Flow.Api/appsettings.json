    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "",
    "ExpiryMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5000",
      "http://localhost:5004",
      "http://localhost:5010"
    ]
  },
  "Audit": {
    "BaseUrl": ""
  },
  "Notifications": {
    "BaseUrl": ""
  },
  "Outbox": {
    "Enabled": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 25,
    "MaxAttempts": 5,
    "BaseBackoffSeconds": 30,
    "BackoffMultiplier": 2.0
