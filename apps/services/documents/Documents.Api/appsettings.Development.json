{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Jwt": {
    "SigningKey": "dev-only-signing-key-minimum-32-chars-long!",
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform"
  },
  "ConnectionStrings": {
    "DocsDb": "Host=helium;Port=5432;Database=heliumdb;Username=postgres"
  },
  "Storage": {
    "Provider": "local"
  },
  "Scanner": {
    "Provider": "mock"
  },
  "AccessToken": {
    "Store": "memory"
  },
  "Documents": {
    "RequireCleanScanForAccess": false
  }
}
