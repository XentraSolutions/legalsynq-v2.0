{
  "Urls": "http://0.0.0.0:5001",
  "Gateway": {
    "ProxyIp": ""
  },
  "ConnectionStrings": {
    "IdentityDb": ""
  },
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "RsaPrivateKey": "REPLACE_VIA_SECRET",
    "RsaPublicKey": "REPLACE_VIA_SECRET",
    "ExpiryMinutes": "60"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AuditClient": {
    "BaseUrl": "http://localhost:5007",
    "ServiceToken": "",
    "SourceSystem": "identity-service",
    "SourceService": "auth-api",
    "TimeoutSeconds": 5
  },
  "Route53": {
    "HostedZoneId": "",
    "BaseDomain": "demo.legalsynq.com",
    "RecordType": "A",
    "RecordValue": "",
    "Ttl": 300,
    "Region": "us-east-2"
  },
  "TenantVerification": {
    "Enabled": true,
    "ExpectedCnameTarget": "",
    "VerificationEndpointPath": "/.well-known/tenant-verify",
    "DnsTimeoutSeconds": 10,
    "HttpTimeoutSeconds": 10,
    "DevBypass": false
  },
  "VerificationRetry": {
    "MaxAttempts": 5,
    "InitialDelaySeconds": 30,
    "MaxDelaySeconds": 300,
    "BackoffMultiplier": 2.0,
    "MaxRetryWindowMinutes": 30
  },
  "AllowedHosts": "*"
