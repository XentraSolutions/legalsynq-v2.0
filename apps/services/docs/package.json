{
  "name": "@legalsynq/docs-service",
  "version": "1.0.0",
  "description": "LegalSynq standalone Docs Service — cloud-agnostic, HIPAA-aligned, enterprise-grade",
  "private": true,
  "scripts": {
    "build":     "tsc --project tsconfig.json",
    "start":     "node dist/server.js",
    "dev":       "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint":      "eslint src --ext .ts",
    "test":      "jest",
    "test:unit": "jest tests/unit",
    "test:int":  "jest tests/integration",
    "db:migrate": "ts-node src/infrastructure/database/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3":            "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "express":                       "^4.19.2",
    "express-async-errors":          "^3.1.1",
    "multer":                        "^1.4.5-lts.1",
    "helmet":                        "^7.1.0",
    "cors":                          "^2.8.5",
    "compression":                   "^1.7.4",
    "jsonwebtoken":                  "^9.0.2",
    "jwks-rsa":                      "^3.1.0",
    "pg":                            "^8.12.0",
    "zod":                           "^3.23.8",
    "pino":                          "^9.3.2",
    "pino-pretty":                   "^11.2.2",
    "uuid":                          "^10.0.0",
    "file-type":                     "^19.4.0",
    "dotenv":                        "^16.4.5"
  },
  "devDependencies": {
    "@types/express":      "^4.17.21",
    "@types/multer":       "^1.4.11",
    "@types/cors":         "^2.8.17",
    "@types/compression":  "^1.7.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg":           "^8.11.6",
    "@types/uuid":         "^10.0.0",
    "@types/node":         "^20.14.0",
    "@types/jest":         "^29.5.12",
    "@types/supertest":    "^6.0.2",
    "typescript":          "^5.5.2",
    "ts-node-dev":         "^2.0.0",
    "ts-node":             "^10.9.2",
    "jest":                "^29.7.0",
    "ts-jest":             "^29.2.2",
    "supertest":           "^7.0.0",
    "eslint":              "^9.6.0"
  }
}
