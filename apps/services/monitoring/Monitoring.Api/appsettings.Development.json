{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Monitoring": {
    "Scheduler": {
      "Enabled": true,
      "IntervalSeconds": 15
    },
    "HttpCheck": {
      "TimeoutSeconds": 5
    }
  },
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "REPLACE_VIA_SECRET_minimum_32_characters_long"
  },
  "MonitoringBootstrap": {
    "Enabled": true
  }
}
